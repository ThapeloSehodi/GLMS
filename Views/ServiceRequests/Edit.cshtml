@model GLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Service Request</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit">

            <!-- IMPORTANT HIDDEN ID -->

            <input type="hidden" asp-for="Id" />

            <!-- VALIDATION -->

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <!-- CONTRACT -->

            <div class="form-group mb-3">

                <label asp-for="ContractId"
                       class="control-label"></label>

                <select asp-for="ContractId"
                        class="form-control"
                        asp-items="ViewBag.ContractId">
                </select>

            </div>

            <!-- DESCRIPTION -->

            <div class="form-group mb-3">

                <label asp-for="Description"
                       class="control-label"></label>

                <input asp-for="Description"
                       class="form-control" />

                <span asp-validation-for="Description"
                      class="text-danger"></span>

            </div>

            <!-- FOREIGN AMOUNT -->

            <div class="form-group mb-3">

                <label asp-for="ForeignAmount"
                       class="control-label"></label>

                <input asp-for="ForeignAmount"
                       class="form-control" />

                <span asp-validation-for="ForeignAmount"
                      class="text-danger"></span>

            </div>

            <!-- CURRENCY -->

            <div class="form-group mb-3">

                <label asp-for="CurrencyType"
                       class="control-label"></label>

                <select asp-for="CurrencyType"
                        class="form-control">

                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                    <option value="GBP">GBP</option>
                    <option value="AED">AED</option>
                    <option value="BWP">BWP</option>

                </select>

                <span asp-validation-for="CurrencyType"
                      class="text-danger"></span>

            </div>

            <!-- COST ZAR -->

            <div class="form-group mb-3">

                <label asp-for="CostZAR"
                       class="control-label"></label>

                <input asp-for="CostZAR"
                       class="form-control"
                       readonly />

            </div>

            <!-- STATUS -->

            <div class="form-group mb-3">

                <label asp-for="Status"
                       class="control-label"></label>

                <input asp-for="Status"
                       class="form-control" />

                <span asp-validation-for="Status"
                      class="text-danger"></span>

            </div>

            <!-- BUTTON -->

            <div class="form-group">

                <input type="submit"
                       value="Save"
                       class="btn btn-primary" />

            </div>

        </form>

    </div>
</div>

<div class="mt-3">

    <a asp-action="Index">
        Back to List
    </a>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}