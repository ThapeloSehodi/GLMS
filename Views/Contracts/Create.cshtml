@model GLMS.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<h1>Create Contract</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Create"
              enctype="multipart/form-data">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <!-- CLIENT -->

            <div class="form-group mb-3">
                <label asp-for="ClientId"
                       class="control-label"></label>

                <select asp-for="ClientId"
                        class="form-control"
                        asp-items="ViewBag.ClientId">
                </select>
            </div>

            <!-- START DATE -->

            <div class="form-group mb-3">
                <label asp-for="StartDate"
                       class="control-label"></label>

                <input asp-for="StartDate"
                       class="form-control" />

                <span asp-validation-for="StartDate"
                      class="text-danger"></span>
            </div>

            <!-- END DATE -->

            <div class="form-group mb-3">
                <label asp-for="EndDate"
                       class="control-label"></label>

                <input asp-for="EndDate"
                       class="form-control" />

                <span asp-validation-for="EndDate"
                      class="text-danger"></span>
            </div>

            <!-- STATUS -->

            <div class="form-group mb-3">
                <label asp-for="Status"
                       class="control-label"></label>

                <select asp-for="Status"
                        class="form-control">

                    <option value="Draft">Draft</option>

                    <option value="Active">Active</option>

                    <option value="Expired">Expired</option>

                    <option value="On Hold">On Hold</option>

                </select>

                <span asp-validation-for="Status"
                      class="text-danger"></span>
            </div>

            <!-- SERVICE LEVEL -->

            <div class="form-group mb-3">
                <label asp-for="ServiceLevel"
                       class="control-label"></label>

                <input asp-for="ServiceLevel"
                       class="form-control" />

                <span asp-validation-for="ServiceLevel"
                      class="text-danger"></span>
            </div>

            <!-- PDF FILE -->

            <div class="form-group mb-3">
                <label asp-for="PdfFile"
                       class="control-label">
                    Signed Agreement PDF
                </label>

                <input asp-for="PdfFile"
                       type="file"
                       class="form-control" />

                <span asp-validation-for="PdfFile"
                      class="text-danger"></span>
            </div>

            <!-- SUBMIT -->

            <div class="form-group">
                <input type="submit"
                       value="Create"
                       class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">
        Back to List
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}